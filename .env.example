# ─────────────────────────────────────────────────────────────────────────────
# Feedhunt — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Frontend (Vite — must be prefixed VITE_) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The inbox address displayed to users so they know where to subscribe
# (this is purely cosmetic — no logic depends on it)
VITE_NEWSLETTER_INBOX_DISPLAY=newsletters@feedhunt.app

# ── Anthropic (Feed Creator AI feature) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Newsletter IMAP ───────────────────────────────────────────────────────────
# IMAP credentials for the dedicated newsletter inbox.
# Feedhunt connects to this mailbox to fetch and parse incoming newsletters.

NEWSLETTER_IMAP_HOST=imap.example.com
NEWSLETTER_IMAP_PORT=993
NEWSLETTER_IMAP_USER=newsletters@feedhunt.app
NEWSLETTER_IMAP_PASSWORD=your-imap-password
NEWSLETTER_IMAP_TLS=true

# ── Cron secret (optional — protects the /api/cron/scrape endpoint) ───────────
CRON_SECRET=your-cron-secret
